---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const guides = await getCollection('guides');
const sortedGuides = [...guides].sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Guides | Mazda MX-5 NB Maintenance Manual">
  <main id="main-content" class="mx-auto max-w-screen-xl px-4 py-10 lg:px-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-secondary">Maintenance Guides</h1>
      <p class="mt-2 text-slate-700">App shell scaffold with one example guide page.</p>
    </header>

    <div class="grid gap-4 md:grid-cols-2">
      {
        sortedGuides.map((guide) => (
          <a href={`/guides/${guide.slug}/`} class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-primary">
            <h2 class="text-lg font-semibold text-secondary">{guide.data.title}</h2>
            <p class="mt-2 text-sm text-slate-700">{guide.data.summary}</p>
            <dl class="mt-3 flex flex-wrap gap-3 text-xs uppercase tracking-[0.08em] text-slate-500">
              <div>
                <dt class="inline">Difficulty:</dt>
                <dd class="ml-1 inline">{guide.data.difficultyLabel}</dd>
              </div>
              <div>
                <dt class="inline">Time:</dt>
                <dd class="ml-1 inline">{guide.data.estimatedTime}</dd>
              </div>
            </dl>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
