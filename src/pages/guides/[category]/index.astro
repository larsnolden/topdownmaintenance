---
import { getCollection } from 'astro:content';
import Breadcrumb from '@components/Breadcrumb.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { CATEGORY_LABELS, type GuideCategory } from '@lib/categories';

interface Props {
  category: GuideCategory;
}

export async function getStaticPaths() {
  const categories = Object.keys(CATEGORY_LABELS) as GuideCategory[];

  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

const { category } = Astro.props as Props;
const categoryLabel = CATEGORY_LABELS[category];

const guides = (await getCollection('guides'))
  .filter((guide) => guide.data.category === category)
  .sort((a, b) => {
    const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
    const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
    return orderA - orderB || a.data.title.localeCompare(b.data.title);
  });
---

<BaseLayout title={`${categoryLabel} Guides | Mazda MX-5 NB Maintenance Manual`}>
  <main id="main-content" class="mx-auto max-w-screen-xl space-y-6 px-4 py-10 lg:px-6">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Guides', href: '/guides/' },
        { label: categoryLabel }
      ]}
    />

    <header>
      <h1 class="text-3xl font-bold tracking-tight text-secondary">{categoryLabel}</h1>
      <p class="mt-2 text-slate-700">
        {guides.length} guide{guides.length === 1 ? '' : 's'} in this section.
      </p>
    </header>

    {
      guides.length > 0 ? (
        <section class="grid gap-4 md:grid-cols-2">
          {
            guides.map((guide) => (
              <a
                href={`/guides/${guide.slug}/`}
                class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-primary"
              >
                <h2 class="text-lg font-semibold text-secondary">{guide.data.title}</h2>
                <p class="mt-2 text-sm text-slate-700">{guide.data.summary}</p>
                <dl class="mt-3 flex flex-wrap gap-3 text-xs uppercase tracking-[0.08em] text-slate-500">
                  <div>
                    <dt class="inline">Difficulty:</dt>
                    <dd class="ml-1 inline">{guide.data.difficultyLabel}</dd>
                  </div>
                  <div>
                    <dt class="inline">Time:</dt>
                    <dd class="ml-1 inline">{guide.data.estimatedTime}</dd>
                  </div>
                </dl>
              </a>
            ))
          }
        </section>
      ) : (
        <section class="rounded-xl border border-slate-200 bg-white p-6 text-slate-700">
          No guides are published in this section yet.
        </section>
      )
    }
  </main>
</BaseLayout>
