---
import { getCollection } from 'astro:content';
import Breadcrumb from '@components/Breadcrumb.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { CATEGORY_LABELS, type GuideCategory } from '@lib/categories';
import { menuSections } from '@lib/navigation';

interface Props {
  category: GuideCategory;
  entry: string;
  entryLabel: string;
}

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  const existingGuideSlugs = new Set(guides.map((guide) => guide.slug));

  return menuSections.flatMap((section) =>
    section.items
      .filter((item) => {
        const guideSlug = item.guideSlug ?? `${section.slug}/${item.slug}`;
        return !existingGuideSlugs.has(guideSlug);
      })
      .map((item) => ({
        params: { category: section.slug, entry: item.slug },
        props: { category: section.slug, entry: item.slug, entryLabel: item.label }
      }))
  );
}

const { category, entry, entryLabel } = Astro.props as Props;
const categoryLabel = CATEGORY_LABELS[category];
---

<BaseLayout title={`${entryLabel} | Mazda MX-5 NB Maintenance Manual`}>
  <main id="main-content" class="mx-auto max-w-screen-lg space-y-6 px-4 py-10 lg:px-6">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Guides', href: '/guides/' },
        { label: categoryLabel, href: `/guides/${category}/` },
        { label: entryLabel }
      ]}
    />

    <section class="rounded-xl border border-slate-200 bg-white p-6 sm:p-8">
      <h1 class="text-3xl font-bold tracking-tight text-secondary">{entryLabel}</h1>
      <p class="mt-4 text-slate-700">
        This entry does not yet exist.
      </p>
      <p class="mt-2 text-slate-700">
        It is planned in the <strong>{categoryLabel}</strong> section and will be published in a future update.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`/guides/${category}/`} class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white">
          Back to {categoryLabel}
        </a>
        <a href="/guides/" class="rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-secondary">
          Browse all guides
        </a>
      </div>

      <p class="mt-6 text-xs text-slate-500">Placeholder slug: <code>{category}/{entry}</code></p>
    </section>
  </main>
</BaseLayout>
