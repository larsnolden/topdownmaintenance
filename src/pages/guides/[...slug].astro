---
import { getCollection, render } from 'astro:content';
import GuideLayout from '@layouts/GuideLayout.astro';
import { buildNavTree } from '@lib/navigation';
import { CATEGORY_LABELS } from '@lib/categories';

export async function getStaticPaths() {
  const guides = await getCollection('guides');

  return guides.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const allGuides = await getCollection('guides');
const navTree = buildNavTree(allGuides);
---

<GuideLayout
  title={entry.data.title}
  summary={entry.data.summary}
  categoryLabel={CATEGORY_LABELS[entry.data.category]}
  categoryPath={`/guides/${entry.data.category}/`}
  navTree={navTree}
  currentPath={`/guides/${entry.slug}/`}
  headings={headings}
  difficulty={entry.data.difficulty}
  difficultyLabel={entry.data.difficultyLabel}
  estimatedTime={entry.data.estimatedTime}
  applicableModels={entry.data.applicableModels}
  updatedAt={entry.data.updatedAt}
>
  <Content />
</GuideLayout>
