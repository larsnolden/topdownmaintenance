---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-slate-600">
  <ol class="flex flex-wrap items-center gap-2">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && <span aria-hidden="true" class="text-slate-400">/</span>}
          {item.href ? (
            <a href={item.href} class="hover:text-primary">{item.label}</a>
          ) : (
            <span class="font-semibold text-secondary">{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
