---
import { FULL_BRAND, SITE_NAME } from '@lib/brand';

interface Props {
  showNavToggle?: boolean;
}

const { showNavToggle = false } = Astro.props;
---

<header class="sticky top-0 z-30 border-b border-slate-200 bg-surface/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-screen-2xl items-center justify-between gap-4 px-4 lg:px-6">
    <div class="flex items-center gap-3">
      {
        showNavToggle && (
          <button
            id="nav-toggle"
            type="button"
            class="rounded-md border border-slate-300 px-3 py-1.5 text-sm font-semibold lg:hidden"
            aria-controls="side-nav"
            aria-expanded="false"
          >
            Menu
          </button>
        )
      }
      <a href="/" class="flex items-center gap-3 text-lg font-bold tracking-tight text-secondary">
        <img
          src="/brand/logo.png"
          alt={`${FULL_BRAND} logo`}
          width="1365"
          height="768"
          class="h-10 w-auto rounded-sm border border-slate-200 bg-white p-0.5"
        />
        <span>{SITE_NAME}</span>
      </a>
    </div>

    <nav class="hidden items-center gap-5 text-sm font-semibold text-slate-600 md:flex">
      <a class="hover:text-primary" href="/">Home</a>
      <a class="hover:text-primary" href="/guides/">Guides</a>
      <a class="hover:text-primary" href="/reference/">Reference</a>
      <a class="hover:text-primary" href="/about/">About</a>
    </nav>
  </div>
</header>
