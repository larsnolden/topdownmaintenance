---
import { FULL_BRAND } from '@lib/brand';
---

<footer class="mt-16 border-t border-slate-200 bg-surface-alt">
  <div class="mx-auto flex max-w-screen-2xl flex-col gap-2 px-4 py-8 text-sm text-slate-600 lg:px-6">
    <p class="flex items-center gap-2 font-semibold text-secondary">
      <img
        src="/brand/logo.png"
        alt={`${FULL_BRAND} logo`}
        width="1365"
        height="768"
        class="h-7 w-auto rounded-sm border border-slate-200 bg-white p-0.5"
      />
      <span>{FULL_BRAND}</span>
    </p>
    <p>Static-first documentation for 1998-2005 MX-5 maintenance workflows.</p>
  </div>
</footer>
