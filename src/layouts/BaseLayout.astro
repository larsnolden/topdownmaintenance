---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  showNavToggle?: boolean;
}

const {
  title,
  description = 'Mazda MX-5 NB maintenance and repair documentation.',
  showNavToggle = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/brand/logo.png" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-secondary antialiased">
    <Header showNavToggle={showNavToggle} />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-slate-900 focus:px-3 focus:py-2 focus:text-white">
      Skip to content
    </a>
    <slot />
    <Footer />
  </body>
</html>
