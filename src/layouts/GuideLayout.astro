---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import SideNav from '@components/SideNav.astro';
import TableOfContents from '@components/TableOfContents.astro';
import type { NavItem } from '@lib/navigation';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  summary: string;
  categoryLabel: string;
  categoryPath: string;
  navTree: NavItem[];
  currentPath: string;
  headings: Heading[];
  difficulty: number;
  difficultyLabel: string;
  estimatedTime: string;
  applicableModels: string[];
  updatedAt?: string;
}

const {
  title,
  summary,
  categoryLabel,
  categoryPath,
  navTree,
  currentPath,
  headings,
  difficulty,
  difficultyLabel,
  estimatedTime,
  applicableModels,
  updatedAt
} = Astro.props;

const stars = '★'.repeat(difficulty) + '☆'.repeat(Math.max(0, 5 - difficulty));
---

<BaseLayout title={`${title} | Mazda MX-5 NB Manual`} description={summary} showNavToggle={true}>
  <div class="mx-auto max-w-screen-2xl px-4 py-6 lg:px-6">
    <div data-nav-backdrop class="fixed inset-0 z-30 hidden bg-slate-900/40 lg:hidden"></div>

    <div class="guide-grid grid gap-8">
      <SideNav tree={navTree} currentPath={currentPath} />

      <main id="main-content" class="min-w-0 space-y-6">
        <Breadcrumb
          items={[
            { label: 'Home', href: '/' },
            { label: 'Guides', href: '/guides/' },
            { label: categoryLabel, href: categoryPath },
            { label: title }
          ]}
        />

        <header class="space-y-4 rounded-xl border border-slate-200 bg-surface-alt p-6">
          <h1 class="text-3xl font-bold tracking-tight text-secondary">{title}</h1>
          <p class="max-w-3xl text-slate-700">{summary}</p>

          <dl class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <dt class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">Difficulty</dt>
              <dd class="mt-1 font-semibold text-secondary">{difficultyLabel}</dd>
              <dd class="text-sm text-slate-600">{stars}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <dt class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">Est. Time</dt>
              <dd class="mt-1 font-semibold text-secondary">{estimatedTime}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <dt class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">Models</dt>
              <dd class="mt-1 font-semibold text-secondary">{applicableModels.join(' & ')}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <dt class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">Last Updated</dt>
              <dd class="mt-1 font-semibold text-secondary">{updatedAt ?? 'Unspecified'}</dd>
            </div>
          </dl>
        </header>

        <article class="prose prose-slate max-w-none rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <slot />
        </article>
      </main>

      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const sideNav = document.querySelector('[data-side-nav]');
  const backdrop = document.querySelector('[data-nav-backdrop]');
  const toggleButton = document.getElementById('nav-toggle');
  const closeButton = sideNav?.querySelector('[data-nav-close]');

  if (sideNav && backdrop) {
    const openNav = () => {
      sideNav.classList.remove('-translate-x-full');
      backdrop.classList.remove('hidden');
      toggleButton?.setAttribute('aria-expanded', 'true');
    };

    const closeNav = () => {
      sideNav.classList.add('-translate-x-full');
      backdrop.classList.add('hidden');
      toggleButton?.setAttribute('aria-expanded', 'false');
    };

    toggleButton?.addEventListener('click', () => {
      if (sideNav.classList.contains('-translate-x-full')) {
        openNav();
      } else {
        closeNav();
      }
    });

    closeButton?.addEventListener('click', closeNav);
    backdrop.addEventListener('click', closeNav);

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeNav();
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) {
        backdrop.classList.add('hidden');
        sideNav.classList.remove('-translate-x-full');
      } else {
        sideNav.classList.add('-translate-x-full');
      }
    });
  }
</script>
